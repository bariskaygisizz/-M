{
  "expo": {
    "name": "BalıkAtlas",
    "slug": "balikatlas",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "balikatlas",
    "primaryColor": "#084A5C",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#084A5C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bariskaygisiz.balikatlas",
      "buildNumber": "1",
      "infoPlist": {
        "CFBundleDisplayName": "BalıkAtlas",
        "ITSAppUsesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyTracking": false,
        "NSPrivacyTrackingDomains": [],
        "NSPrivacyCollectedDataTypes": [],
        "NSPrivacyAccessedAPITypes": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#084A5C"
      },
      "package": "com.bariskaygisiz.balikatlas",
      "versionCode": 1,
      "permissions": []
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
