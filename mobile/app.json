{
  "expo": {
    "name": "BalıkAtlas",
    "slug": "balikatlas",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "balikatlas",
    "primaryColor": "#0a0a0a",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bariskaygisiz.balikatlas",
      "buildNumber": "2",
      "infoPlist": {
        "CFBundleDisplayName": "BalıkAtlas",
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Balığı kamerayla tarayıp AI ile tanımak için kamera erişimi gerekir. Fotoğraf yalnızca sizin başlattığınız tarama için kullanılır.",
        "NSPhotoLibraryUsageDescription": "Galeriden balık fotoğrafı seçerek AI tanıma yapmak için gerekir."
      },
      "privacyManifests": {
        "NSPrivacyTracking": false,
        "NSPrivacyTrackingDomains": [],
        "NSPrivacyCollectedDataTypes": [],
        "NSPrivacyAccessedAPITypes": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.bariskaygisiz.balikatlas",
      "versionCode": 2,
      "permissions": ["CAMERA"]
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Balığı kamerayla tarayıp AI ile tanımak için kamera erişimi gerekir."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "privacyPolicyUrl": "https://example.com/balikatlas-privacy",
      "termsOfServiceUrl": "https://example.com/balikatlas-terms",
      "supportEmail": "kaygisizbaris9@gmail.com",
      "iapMonthly": "com.bariskaygisiz.balikatlas.premium.monthly",
      "iapYearly": "com.bariskaygisiz.balikatlas.premium.yearly"
    }
  }
}
